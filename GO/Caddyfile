# Caddyfile - TLS termination for AnsibleRelay
# Development configuration (auto HTTP)
# Production: replace with actual domain and cert management

# HTTP to HTTPS redirect + TLS termination
:80 {
  redir https://{host}{uri}
}

:443 {
  tls internal

  # Relay API endpoints (7770)
  reverse_proxy /api/register relay-api:7770
  reverse_proxy /api/admin relay-api:7770
  reverse_proxy /api/token relay-api:7770
  reverse_proxy /api/exec relay-api:7770
  reverse_proxy /api/upload relay-api:7770
  reverse_proxy /api/fetch relay-api:7770
  reverse_proxy /api/inventory relay-api:7770
  reverse_proxy /api/async_status relay-api:7770
  reverse_proxy /health relay-api:7770

  # WebSocket connections (7772)
  reverse_proxy /ws/agent relay-api:7772 {
    header_up Connection *
    header_up Upgrade websocket
  }

  # Admin endpoints (7771)
  reverse_proxy /api/admin/minions relay-api:7771
  reverse_proxy /api/admin/authorize relay-api:7771
  reverse_proxy /api/admin/revoke relay-api:7771

  # Compression
  encode gzip

  # Logging
  log {
    output stdout
    format json
  }
}
